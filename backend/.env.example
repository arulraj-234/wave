# Wave Backend Configuration
# Copy this file to .env and fill in your values

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=wave_db
DB_PORT=3306
DB_SSL_MODE=false

# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JioSaavn API microservice URL
SAAVN_API_URL=http://localhost:3001/api

# Flask settings
FLASK_APP=app.py
FLASK_ENV=development

# Optional: Comma-separated allowed CORS origins for production
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Production TiDB (used by: python migrate.py --prod)
# PROD_DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
# PROD_DB_USER=your_tidb_user
# PROD_DB_PASSWORD=your_tidb_password
# PROD_DB_NAME=wave_db
# PROD_DB_PORT=4000
# PROD_DB_SSL_MODE=true
