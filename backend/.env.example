# Wave Backend Configuration
# Copy this file to .env and fill in your values

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=wave_db
DB_PORT=3306
DB_SSL_MODE=false

# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JioSaavn API microservice URL
SAAVN_API_URL=http://localhost:3001/api

# Flask settings
FLASK_APP=app.py
FLASK_ENV=development

# Optional: Comma-separated allowed CORS origins for production
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
